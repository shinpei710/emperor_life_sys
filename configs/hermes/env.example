# =============================================================================
# Hermes Agent — danghuangshang 配套 .env 模板
# 用法: cp configs/hermes/env.example ~/.hermes/.env  然后填值
# =============================================================================

# ===== LLM 提供商(任选其一,Hermes 自动检测) ======================
# OpenRouter(推荐,200+ 模型一站式)
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic 直连
# ANTHROPIC_API_KEY=sk-ant-...

# 自托管 / 兼容 OpenAI 网关(国内常用)
# OPENAI_BASE_URL=https://your-llm-provider-api-url
# OPENAI_API_KEY=sk-...

# Nous Portal(Hermes 母公司,自带 OAuth)
# 不用配 key,用 `hermes login`

# ===== Discord ====================================================
# DISCORD_BOT_TOKEN=
# DISCORD_APPLICATION_ID=
# DISCORD_ALLOWED_ROLES=  # 可选,逗号分隔角色 ID,只有这些 role 能 @ 机器人

# ===== Telegram ===================================================
# TELEGRAM_BOT_TOKEN=

# ===== 飞书 / Lark =================================================
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ===== Slack ======================================================
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_TOKEN=xoxb-...

# ===== 工具 API key(可选) =========================================
# EXA_API_KEY=         # Exa 神经搜索
# FIRECRAWL_API_KEY=   # Firecrawl 抓页
# FAL_KEY=             # fal.ai 图像/视频生成
# HONCHO_API_KEY=      # 跨会话用户建模
